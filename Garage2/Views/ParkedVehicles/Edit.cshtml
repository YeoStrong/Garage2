@model Garage2.Models.ViewModels.ParkedVehicleFormViewModel

@{
    ViewData["Title"] = "Modify Vehicle";
}

<div class="container col-md-8">
    <div class="col-md-8 mx-auto">
        <div>
            <a asp-action="Index" class="sv-back-link small">&larr; Back to overview</a>
        </div>

        <div class="garage-header">
            <h1>Modify Vehicle</h1>
            <p>Update the information for this parked vehicle</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-12">
                <div class="garage-card">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <div class="alert alert-info">
                                <strong>Check In Time:</strong>
                                <span>@Model.ArrivalTime.ToString("dddd, yyyy-MM-dd HH:mm")</span>

                                <br />

                                <div class="parked-duration">
                                    <strong>Parked Duration: </strong>
                                    <span id="parkedDuration"></span>

                                    <input type="hidden" id="arrivalTimeValue"
                                        value="@Model.ArrivalTime.ToString("yyyy-MM-ddTHH:mm:ss")" />
                                </div>
                            </div>
                        </div>

                        <partial name="_VehicleForm" model="Model" />

                        <div class="form-group mt-4 d-flex gap-4">
                            <button type="submit" class="btn garage-btn w-50">Save Changes</button>

                            <a asp-action="Index" class="btn btn-secondary w-50">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
