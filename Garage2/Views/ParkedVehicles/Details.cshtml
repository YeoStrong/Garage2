@model Garage2.Models.Entities.ParkedVehicle

@{
    ViewData["Title"] = "Vehicle Details";
}

<h1>Vehicle Details</h1>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Registration Number</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.RegistrationNumber)</dd>

            <dt class="col-sm-4">Vehicle Type</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.VehicleType)</dd>

            <dt class="col-sm-4">Color</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Color)</dd>

            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Brand)</dd>

            <dt class="col-sm-4">Model</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Model)</dd>

            <dt class="col-sm-4">Number of Wheels</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.NumberOfWheels)</dd>

            <dt class="col-sm-4">Arrival Time</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.ArrivalTime)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to Overview</a>
</div>