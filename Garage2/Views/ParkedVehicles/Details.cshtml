@using Garage2.Helpers

@model Garage2.Models.Entities.ParkedVehicle

@{
    ViewData["Title"] = "Vehicle Details";

    var badgeColor = VehicleTypeBadgeHelper.GetBadgeColor(Model.VehicleType);

    var badgeTextColor = VehicleTypeBadgeHelper.GetBadgeTextColor(Model.VehicleType);
}

<div class="container">
    <div class="col-md-8 mx-auto">
        <a asp-action="Index" class="sv-back-link small">&larr; Back to overview</a>

        <div class="garage-header">
            <h3>Parked Vehicle Details</h3>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-12">
                <div class="card sv-card mt-3">
                    <div class="sv-flag-bar"></div>

                    <div class="card-body p-4">
                        @Html.HiddenFor(m => m.Id)
                        @Html.HiddenFor(m => m.ArrivalTime)

                        <div class="alert alert-info">
                            <div class="mb-2">
                                <strong>Checked In Time:</strong>
                                <span>@Model.ArrivalTime.ToString("dddd, yyyy-MM-dd HH:mm")</span>
                            </div>

                            <div class="parked-duration">
                                <strong>Parked Duration: </strong>
                                <span class="duration-cell"
                                      data-arrival-time='@Model.ArrivalTime.ToString("yyyy-MM-ddTHH:mm:ss")'>
                                </span>
                            </div>
                        </div>

                        <hr class="my-3" />

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h4 class="m-2 mt-0">@Model.RegistrationNumber</h4>
                                <span class="sv-badge" style="background-color:@badgeColor; color:@badgeTextColor;">
                                    @Model.VehicleType.GetDisplayName()
                                </span>
                            </div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn sv-btn-details w-25">
                                Edit
                            </a>
                        </div>

                        <dl class="row mb-0 gy-2">
                            <dt class="col-5 sv-label">Color</dt>
                            <dd class="col-7 mb-0">@Model.Color</dd>

                            <dt class="col-5 sv-label">Brand</dt>
                            <dd class="col-7 mb-0">@Model.Brand</dd>

                            <dt class="col-5 sv-label">Model</dt>
                            <dd class="col-7 mb-0">@Model.Model</dd>

                            <dt class="col-5 sv-label">Wheels</dt>
                            <dd class="col-7 mb-0">@Model.NumberOfWheels</dd>

                            <dt class="col-5 sv-label">Parking Spot</dt>
                            <dd class="col-7 mb-0">@SpotHelper.GetSpotDisplay(Model.AssignedSpotNumber, Model.VehicleType)</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>