@model Garage2.Models.Entities.ParkedVehicle

@{
    ViewData["Title"] = "Vehicle Details";

    var badgeColor = Model.VehicleType switch
    {
        Garage2.Models.Enums.VehicleType.Car => "primary",
        Garage2.Models.Enums.VehicleType.Motorcycle => "warning",
        Garage2.Models.Enums.VehicleType.Truck => "dark",
        Garage2.Models.Enums.VehicleType.Bus => "success",
        _ => "secondary"
    };
}

<div class="container mt-4">
    <a asp-action="Index" class="text-decoration-none text-muted small">&larr; Back to overview</a>

    <div class="card shadow-sm mt-3" style="max-width: 480px; border-radius: 12px;">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h4 class="mb-1">@Model.RegistrationNumber</h4>
                    <span class="badge bg-@badgeColor">@Model.VehicleType</span>
                </div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                    Edit
                </a>
            </div>

            <hr class="my-3" />

            <dl class="row mb-0 gy-2">
                <dt class="col-5 text-muted fw-normal">Color</dt>
                <dd class="col-7 mb-0">@Model.Color</dd>

                <dt class="col-5 text-muted fw-normal">Brand</dt>
                <dd class="col-7 mb-0">@Model.Brand</dd>

                <dt class="col-5 text-muted fw-normal">Model</dt>
                <dd class="col-7 mb-0">@Model.Model</dd>

                <dt class="col-5 text-muted fw-normal">Wheels</dt>
                <dd class="col-7 mb-0">@Model.NumberOfWheels</dd>

                <dt class="col-5 text-muted fw-normal">Arrived</dt>
                <dd class="col-7 mb-0">@Model.ArrivalTime.ToString("dd MMM yyyy, HH:mm")</dd>
            </dl>
        </div>
    </div>
</div>