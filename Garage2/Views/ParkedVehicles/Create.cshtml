@model Garage2.Models.ViewModels.ParkedVehicleFormViewModel

@{
    ViewData["Title"] = "Check in";
}

<div class="container">
    <div class="col-md-8 mx-auto">
        <a asp-action="Index" class="sv-back-link small">&larr; Back to overview</a>

        <div class="garage-header">
            <h3>Check In Vehicle</h3>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-12">
                <div class="card sv-card mt-3">
                    <div class="sv-flag-bar"></div>
                    
                    <div class="card-body p-4">
                        <div class="alert alert-info">
                            <strong>Current Time (Check In Time):</strong> <span id="liveClock">Loading...</span>
                        </div>

                        <hr class="my-3"/>

                        <form asp-action="Create">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <partial name="_VehicleForm" model="Model"/>

                            <div class="form-group mt-4 d-flex gap-4">
                                <button type="submit" class="btn garage-btn w-50">Check In</button>

                                <a asp-action="Index" class="btn btn-secondary w-50">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
                <partial name="_SpotMap" model="ViewBag.SpotMap" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        updateClock();
        setInterval(updateClock, 1000);    
    </script>
}