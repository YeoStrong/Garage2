@model Garage2.Models.ViewModels.ParkedVehicleCreateViewModel

@{
    ViewData["Title"] = "Check in";
}

<h1>Create</h1>
<h4>ParkedVehicle</h4>
<hr />

<div class="alert alert-info col-md-4">
    <strong>Current Time (Check In Time):</strong> <span id="liveClock">Loading...</span>
</div>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <partial name="_VehicleForm" model="Model" />

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function updateClock() {
            const now = new Date();

            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const seconds = String(now.getSeconds()).padStart(2, '0');

            const timeString = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;

            document.getElementById('liveClock').textContent = timeString;
        }

        updateClock();
        setInterval(updateClock, 1000);
    </script>
}