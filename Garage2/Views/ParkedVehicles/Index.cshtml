@using Garage2.Helpers

@model IEnumerable<Garage2.Models.ViewModels.ParkedVehicleOverviewViewModel>

@{
    ViewData["Title"] = "Overview";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="successAlert" class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="container mt-4">
    <!-- <div class="sv-flag-bar-rounded"></div> -->

    <div class="d-flex justify-content-between align-items-center mb-4 gap-3">
        <form asp-action="Index" method="get" class="d-flex align-items-center m-0">
            <div class="input-group">
                <input type="text"
                    id="searchBox"
                    name="searchString"
                    class="form-control"
                    placeholder="Search text"
                    value="@Context.Request.Query["searchString"]"
                    autofocus
                />
                <input type="text"
                    id="searchTimeBox"
                    name="searchTime"
                    class="form-control"
                    placeholder="Search Time"
                    value="@Context.Request.Query["searchTime"]"
                />

                <button type="submit" class="btn sv-btn-create">Search</button>

                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string) ||
                    !string.IsNullOrEmpty(ViewData["CurrentTimeFilter"] as string))
                {
                    <a asp-action="Index"
                       class="btn sv-badge-sm text-dark py-0 d-inline-flex align-items-center fs-6">
                        Clear
                    </a>
                }
            </div>
        </form>

        <a asp-action="Create" class="btn sv-btn-create d-flex align-items-center">
            Check In
        </a>
    </div>

    @{
        var freeSpots = (int)(ViewData["FreeSpotCount"] ?? 0);
        var totalSpots = (int)(ViewData["TotalSpots"] ?? 0);
        var spotAlertClass = freeSpots == 0 ? "alert-danger" : (freeSpots <= 3 ? "alert-warning" : "alert-info");
    }
    <div class="alert @spotAlertClass d-flex justify-content-between align-items-center mb-4" role="status">
        <span><strong>@freeSpots</strong> of <strong>@totalSpots</strong> parking spots free</span>
        <a asp-action="Overview" class="small fw-semibold" style="color: var(--primary-color);">View spot map &rarr;</a>
    </div>

    @if (!Model.Any())
    {
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string) || !string.IsNullOrEmpty(ViewData["CurrentTimeFilter"] as string))
        {
            var searchFilterText = string.Join(" / ", 
                new[] { ViewData["CurrentFilter"] as string, ViewData["CurrentTimeFilter"] as string }
                .Where(s => !string.IsNullOrEmpty(s)));

            <div class="alert alert-warning text-center mt-4" role="alert">
                No vehicles found matching <strong>"@searchFilterText"</strong>.
            </div>
        }
        else
        {
            <div class="alert alert-info text-center mt-4" role="alert">
                The garage is currently empty. No vehicles parked yet!
            </div>
        }
    }
    else
    {
        <div class="mb-3 text-muted">
            <strong>@Model.Count()</strong> @(Model.Count() == 1 ? "vehicle found." : "vehicles found.")
        </div>

        <div class="table-responsive">
            <table class="table sv-table align-middle">
                <thead>
                    <tr>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortOrder="@ViewData["TypeSortParm"]"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               class="sv-nav-link">
                                Vehicle Type
                                @if (ViewData["CurrentSort"]?.ToString() == "TypeAsc")
                                {
                                    <span>▲</span>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "TypeDesc")
                                {

                                    <span>▼</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortOrder="@ViewData["RegSortParm"]"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               class="sv-nav-link">
                                Registration Number
                                @if (ViewData["CurrentSort"]?.ToString() == "RegAsc")
                                {
                                    <span>▲</span>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "RegDesc")
                                {

                                    <span>▼</span>
                                }
                                else if (string.IsNullOrEmpty(ViewData["CurrentSort"] as string))
                                {
                                    <span>▲</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortOrder="@ViewData["DateSortParm"]"
                               asp-route-searchTime="@ViewData["CurrentTimeFilter"]"
                               class="sv-nav-link">
                                Arrival Time
                                @if (ViewData["CurrentSort"]?.ToString() == "DateAsc")
                                {
                                    <span>▲</span>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "DateDesc")
                                {
                                    <span>▼</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortOrder="@ViewData["DurationSortParm"]"
                               asp-route-searchTime="@ViewData["CurrentTimeFilter"]"
                               class="sv-nav-link">
                                Parked Duration
                                @if (ViewData["CurrentSort"]?.ToString() == "DurationAsc")
                                {
                                    <span>▲</span>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "DurationDesc")
                                {
                                    <span>▼</span>
                                }
                            </a>
                        </th>
                        <th>
                           Spot
                        </th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span>@Html.DisplayFor(modelItem => item.VehicleType)</span></td>
                            <td><strong>@Html.DisplayFor(modelItem => item.RegistrationNumber)</strong></td>
                            <td>@item.ArrivalTime.ToString("ddd, dd MMM yyyy, HH:mm")</td>
                            <td data-arrival-time='@item.ArrivalTime.ToString("yyyy-MM-ddTHH:mm:ss")' class="duration-cell"></td>
                            <td>@SpotHelper.GetSpotDisplay(item.AssignedSpotNumber, item.VehicleType)</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn sv-btn-details sv-action-btn w-sm-auto">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn sv-btn-details sv-action-btn w-sm-auto">Update</a>
                                <a asp-action="CheckOut" asp-route-id="@item.Id" class="btn btn-outline-danger sv-action-btn w-sm-auto">Check Out</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        fadeOutSuccessAlert();

        const searchBox = document.getElementById('searchBox');
        if (searchBox)
        {
            searchBox.focus();
            const val = searchBox.value;
            searchBox.value = '';
            searchBox.value = val;
        }

        updateParkedDurations();
        setInterval(updateParkedDurations, 60000);
    </script>
}