@model IEnumerable<Garage2.Models.ViewModels.ParkedVehicleOverviewViewModel>

@{
    ViewData["Title"] = "Overview";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="successAlert" class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="container mt-4">
    <div class="sv-flag-bar-rounded"></div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="sv-header mb-0">Overview</h1>
        <a asp-action="Create" class="btn sv-btn-create">
            + Park a Vehicle
        </a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group" style="max-width: 400px;">
            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Search with Registration Number"
                   value="@Context.Request.Query["searchString"]" /> <button type="submit" class="btn btn-primary">Sök</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
        {
            <div class="alert alert-warning text-center mt-4" role="alert">
                No vehicles found matching <strong>"@ViewData["CurrentFilter"]"</strong>.
            </div>
        }
        else
        {
            <div class="alert alert-info text-center mt-4" role="alert">
                The garage is currently empty. No vehicles parked yet!
            </div>
        }
    }
    else
    {
        <div class="mb-3 text-muted">
            <strong>@Model.Count()</strong> @(Model.Count() == 1 ? "vehicle found." : "vehicles found.")
        </div>

        <div class="table-responsive">
            <table class="table sv-table align-middle">
                <thead>
                    <tr>
                        <th>Vehicle Type</th>
                        <th>Registration Number</th>
                        <th>Arrival Time</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="sv-badge-sm">@Html.DisplayFor(modelItem => item.VehicleType)</span></td>
                            <td><strong>@Html.DisplayFor(modelItem => item.RegistrationNumber)</strong></td>
                            <td>@item.ArrivalTime.ToString("dd MMM yyyy, HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn sv-btn-details sv-action-btn">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary sv-action-btn">Edit</a>
                                <a asp-action="CheckOut" asp-route-id="@item.Id" class="btn btn-outline-danger sv-action-btn">Check Out</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        fadeOutSuccessAlert();
    </script>
}