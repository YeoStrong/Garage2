@model Garage2.Models.ViewModels.GarageStatisticsViewModel

@{
    ViewData["Title"] = "Garage Statistics";
}

<div class="container mt-4">
    <a asp-action="Index" class="sv-back-link small">&larr; Back to overview</a>

    <div class="garage-header">
        <h3>Garage Statistics</h3>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-3">
            <div class="card sv-card p-3 text-center">
                <div class="sv-label">Vehicles Parked</div>
                <div class="fs-3 fw-bold">@Model.TotalVehicles</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card sv-card p-3 text-center">
                <div class="sv-label">Total Wheels</div>
                <div class="fs-3 fw-bold">@Model.TotalWheels</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card sv-card p-3 text-center">
                <div class="sv-label">Estimated Revenue</div>
                <div class="fs-3 fw-bold">@Model.EstimatedCurrentRevenue.ToString("0.00") kr</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card sv-card p-3 text-center">
                <div class="sv-label">Avg. Parked Duration</div>
                <div class="fs-3 fw-bold">@($"{(int)Model.AverageParkedDuration.TotalHours}h {Model.AverageParkedDuration.Minutes}m")</div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h5 class="sv-header">Vehicles by Type</h5>
            <table class="table sv-table">
                <thead>
                    <tr>
                        <th>Vehicle Type</th>
                        <th class="text-end">Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kvp in Model.VehicleCountsByType.OrderByDescending(kvp => kvp.Value))
                    {
                        <tr>
                            <td>@kvp.Key.GetDisplayName()</td>
                            <td class="text-end">@kvp.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-md-6">
            <h5 class="sv-header">Other Facts</h5>
            <ul class="list-group">
                @if (Model.MostCommonType.HasValue)
                {
                    <li class="list-group-item">
                        Most common vehicle type: <strong>@Model.MostCommonType.Value.GetDisplayName()</strong>
                    </li>
                }
                @if (Model.LongestParkedRegistrationNumber != null)
                {
                    <li class="list-group-item">
                        Longest parked: <strong>@Model.LongestParkedRegistrationNumber</strong>
                        (since @Model.LongestParkedArrivalTime?.ToString("dd MMM yyyy, HH:mm"))
                    </li>
                }
            </ul>
        </div>
    </div>
</div>